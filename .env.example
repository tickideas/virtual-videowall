# Database
# For local Docker Compose:
DATABASE_URL="postgresql://videowall:changeme@localhost:5432/videowall?schema=public"

# Redis (optional - for horizontal scaling with rate limiting)
# If not set, will use in-memory rate limiting (not recommended for production with multiple instances)
# For local: redis://localhost:6379
# For Coolify: use the redis service internal URL
REDIS_URL="redis://redis-hostname:6379"

# NextAuth/session settings
# For local: http://localhost:3000
# For production: https://videowall.yourdomain.com
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Admin credentials (for initial setup)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"

# Daily.co
# Get these from https://dashboard.daily.co/developers
DAILY_API_KEY="your-daily-api-key"
DAILY_DOMAIN="your-domain"
NEXT_PUBLIC_DAILY_DOMAIN="your-domain"

# App Settings
NEXT_PUBLIC_APP_NAME="Virtual Video Wall"
NEXT_PUBLIC_MAX_CHURCHES=60
