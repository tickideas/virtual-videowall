# Daily.co Configuration
# Get these from https://dashboard.daily.co/developers

# Your Daily.co API key
DAILY_API_KEY=your_daily_api_key_here

# Your Daily.co subdomain. Use only the subdomain, not the full daily.co host.
DAILY_DOMAIN=your-domain

# Public Daily.co domain (same as DAILY_DOMAIN)
NEXT_PUBLIC_DAILY_DOMAIN=your-domain

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/videowall"
REDIS_URL="redis://localhost:6379"

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_secret_key_here
